rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------
    // GLOBAL HELPERS
    // -------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------
    // PRODUCTS
    // -------------------------------------------------------------
    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200
          && data.price is number && data.price >= 0
          && data.category is string
          && data.images is list && data.images.size() > 0;
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------
    // CATEGORIES
    // -------------------------------------------------------------
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------
    // USERS
    // -------------------------------------------------------------
    function isValidUser(data) {
      return data.uid == request.auth.uid
          && data.email == request.auth.token.email
          && (data.isAdmin == false || !data.diff(existing()).affectedKeys().hasAny(['isAdmin']));
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && incoming().isAdmin == false;
      allow update: if isOwner(userId) && isValidUser(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']);
    }

    // -------------------------------------------------------------
    // ORDERS
    // -------------------------------------------------------------
    function isValidOrder(data) {
      return data.userId == request.auth.uid
          && data.items is list && data.items.size() > 0
          && data.total is number && data.total >= 0
          && data.status == 'pending';
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isEmailVerified() && isValidOrder(incoming()) && incoming().userId == request.auth.uid;
      allow update: if isAdmin(); // Tracking status updates
    }

    // -------------------------------------------------------------
    // ADMINS (READ ONLY / PROTECTED)
    // -------------------------------------------------------------
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false; // Managed via Firebase Console for security
    }

    // -------------------------------------------------------------
    // PROMOTIONS
    // -------------------------------------------------------------
    function isValidPromotion(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200
          && data.imageUrl is string && data.imageUrl.size() < 1000
          && data.active is bool
          && (data.type == 'hero' || data.type == 'card' || data.type == 'sale');
    }

    match /promotions/{promoId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidPromotion(incoming());
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------
    // CONFIG
    // -------------------------------------------------------------
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
