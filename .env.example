# Copy to .env (or run npm run deploy:prepare — will auto-create .env from this file)
DATABASE_URL="file:./data/homaire.db"

# Auth (change in production)
JWT_SECRET="change-me-to-a-long-random-string"
ADMIN_SEED_EMAIL="admin@homaire.local"
ADMIN_SEED_PASSWORD="admin"
STORE_ADMIN_PASSWORD="admin"

# Server
PORT=3000
NODE_ENV=development

# Optional: Gemini
# GEMINI_API_KEY=

# Optional: frontend
# VITE_USE_REMOTE_STORE=true
# VITE_STORE_ADMIN_PASSWORD=admin
